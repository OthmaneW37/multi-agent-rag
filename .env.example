# ============================================================
# CONFIGURATION LLM - WAC Sport Analytics
# ============================================================
# RECOMMANDE : Groq (gratuit, rapide, stable)
# Inscrivez-vous sur https://console.groq.com/ pour obtenir une cle API.
# Groq utilise Llama3-8b qui est plus stable et moins sujet aux hallucinations
# que les modeles locaux via Ollama.
# ============================================================

LLM_PROVIDER=groq
GROQ_API_KEY=votre-cle-groq-ici
GROQ_MODEL=llama3-8b-8192

# Alternative : Ollama (local, lent, necessite un PC puissant)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# Alternative : OpenAI (payant, tres rapide)
# OPENAI_API_KEY=sk-votre-cle-openai
# OPENAI_MODEL=gpt-3.5-turbo

# Alternative : Anthropic (payant, tres rapide)
# ANTHROPIC_API_KEY=votre-cle-anthropic
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ============================================================
# CONFIGURATION RAG
# ============================================================
VECTOR_STORE_PATH=./data/processed/vector_store
DATA_PATH=./data/raw
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
